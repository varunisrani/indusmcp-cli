{
  "name": "indusmcp",
  "version": "0.1.4",
  "description": "IndusMCP CLI — search and install MCP servers locally. Credentials stay on your machine.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "indusmcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.10"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "indusmcp",
    "claude",
    "cli",
    "registry",
    "india-stack"
  ],
  "homepage": "https://indusmcp.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/indusmcp/cli.git"
  },
  "bugs": {
    "url": "https://github.com/indusmcp/cli/issues"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node20 --shims --no-splitting --clean",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "prepublishOnly": "pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "kleur": "^4.1.5",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
